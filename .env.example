# ── API Keys ──────────────────────────────────────────────────────────
# At least ONE extraction backend must be configured.

# Alibaba DashScope (primary LLM backend) — get from aliyun.com
DASHSCOPE_API_KEY=sk-ws-your-key-here

# OpenRouter (fallback LLM backend) — get from openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Google Gemini (fallback LLM backend) — get from aistudio.google.com
GEMINI_API_KEY=your-gemini-key-here

# Ollama Cloud (local/open-source fallback) — get from cloud.ollama.com
OLLAMA_API_KEY=your-ollama-key-here

# ── Optional ──────────────────────────────────────────────────────────
# HTTP proxy for scraping (e.g., "http://proxy:8080")
PROXY_URL=
